{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XenoXanadu Park Data",
  "description": "Schema for national park field guide data files used by XenoXanadu. Each park has a corresponding JSON file in data/ that conforms to this schema.",
  "type": "object",
  "required": ["name", "slug", "state", "region", "coords", "npsCode"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Full display name of the park (e.g., 'Grand Canyon')"
    },
    "slug": {
      "type": "string",
      "description": "URL-safe slug used in file paths (e.g., 'grand-canyon')",
      "pattern": "^[a-z0-9-]+$"
    },
    "state": {
      "type": "string",
      "description": "State(s) the park is located in (e.g., 'Utah', 'Tennessee/North Carolina')"
    },
    "region": {
      "type": "string",
      "description": "Geographic region for filtering and grouping",
      "enum": ["Southwest", "West", "Midwest", "Southeast", "Northeast", "Pacific", "Alaska", "Hawaii"]
    },
    "coords": {
      "type": "array",
      "description": "Park center coordinates as [latitude, longitude]",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "npsCode": {
      "type": "string",
      "description": "NPS 4-letter park code (e.g., 'zion', 'grca')",
      "pattern": "^[a-z]{4}$"
    },
    "area": {
      "type": "string",
      "description": "Park area with units (e.g., '229 mi²')"
    },
    "elevationRange": {
      "type": "string",
      "description": "Elevation range in feet (e.g., '3,666–8,726\\'')"
    },
    "annualVisitors": {
      "type": "string",
      "description": "Approximate annual visitors (e.g., '~5M')"
    },
    "entryFee": {
      "type": "string",
      "description": "Vehicle entry fee (e.g., '$35')"
    },
    "heroImage": {
      "type": "string",
      "description": "URL to park hero/banner image, preferably from NPS",
      "format": "uri"
    },
    "parkEmoji": {
      "type": "string",
      "description": "Emoji representing this park for the favicon (e.g., '🏜️', '🌋', '🏔️')"
    },
    "quickLinks": {
      "type": "object",
      "description": "URLs for the quick access bar at the top of the park page",
      "properties": {
        "conditions": {
          "type": "string",
          "description": "URL to NPS current conditions page"
        },
        "weather": {
          "type": "string",
          "description": "URL to weather forecast (weather.gov preferred)"
        },
        "permits": {
          "type": "string",
          "description": "URL to permits/reservations page"
        },
        "shuttle": {
          "type": ["string", "null"],
          "description": "URL to shuttle info, or null if park has no shuttle system"
        },
        "maps": {
          "type": "string",
          "description": "URL to NPS maps page"
        },
        "campgrounds": {
          "type": "string",
          "description": "URL to campground booking"
        },
        "alerts": {
          "type": "string",
          "description": "URL to NPS alerts page"
        },
        "parkSpecific": {
          "type": "object",
          "description": "One extra quick link specific to this park",
          "properties": {
            "url": { "type": "string" },
            "label": { "type": "string" },
            "icon": { "type": "string" }
          }
        }
      }
    },
    "trails": {
      "type": "array",
      "description": "Array of trail objects for the trail guide section",
      "items": {
        "type": "object",
        "required": ["name", "difficulty"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Trail display name"
          },
          "difficulty": {
            "type": "string",
            "description": "Trail difficulty rating",
            "enum": ["Easy", "Moderate", "Strenuous"]
          },
          "distance": {
            "type": "string",
            "description": "Round-trip distance with units (e.g., '5.4 mi')"
          },
          "elevationGain": {
            "type": "string",
            "description": "Elevation gain in feet (e.g., '1,488\\'')"
          },
          "time": {
            "type": "string",
            "description": "Estimated hiking time (e.g., '~4 hr')"
          },
          "description": {
            "type": "string",
            "description": "Trail description with insider tips — NOT generic NPS copy"
          },
          "tips": {
            "type": "array",
            "description": "Array of insider tip strings for this trail",
            "items": { "type": "string" }
          },
          "links": {
            "type": "array",
            "description": "Array of [label, url] pairs for trail resources",
            "items": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "shuttleStop": {
            "type": ["string", "null"],
            "description": "Shuttle stop name/number, or null if not on shuttle route"
          },
          "permitRequired": {
            "type": "boolean",
            "description": "Whether a permit is needed for this trail"
          },
          "coordinates": {
            "type": ["array", "null"],
            "description": "Trailhead coordinates as [lat, lng], or null if unknown",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "camping": {
      "type": "array",
      "description": "Array of campground objects",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Campground name"
          },
          "sites": {
            "type": ["integer", "string"],
            "description": "Number of sites or description"
          },
          "fee": {
            "type": "string",
            "description": "Nightly fee (e.g., '$30/night')"
          },
          "reservations": {
            "type": "boolean",
            "description": "Whether reservations are accepted/required"
          },
          "season": {
            "type": "string",
            "description": "Open season (e.g., 'March–November')"
          },
          "hookups": {
            "type": "boolean",
            "description": "Whether RV hookups are available"
          },
          "description": {
            "type": "string",
            "description": "Practical description with tips"
          },
          "bookingUrl": {
            "type": "string",
            "description": "Direct booking URL on Recreation.gov"
          },
          "coordinates": {
            "type": ["array", "null"],
            "description": "Campground coordinates as [lat, lng]",
            "items": { "type": "number" }
          }
        }
      }
    },
    "gearNotes": {
      "type": "string",
      "description": "Park-specific gear notes and recommendations"
    },
    "seasons": {
      "type": "object",
      "description": "When-to-visit information",
      "properties": {
        "best": {
          "type": "string",
          "description": "Best time to visit (e.g., 'March–May and September–November')"
        },
        "avoid": {
          "type": "string",
          "description": "Worst time to visit and why"
        },
        "notes": {
          "type": "string",
          "description": "Additional seasonal details"
        },
        "spring": { "type": "string" },
        "summer": { "type": "string" },
        "fall": { "type": "string" },
        "winter": { "type": "string" }
      }
    },
    "safety": {
      "type": "object",
      "description": "Safety information organized by hazard type",
      "properties": {
        "primaryHazards": {
          "type": "array",
          "description": "List of primary hazard descriptions",
          "items": { "type": "string" }
        },
        "emergencyNumber": {
          "type": "string",
          "description": "Park-specific emergency dispatch number"
        },
        "nearestHospital": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "driveTime": { "type": "string" }
          }
        },
        "visitorCenterPhone": {
          "type": "string",
          "description": "Main visitor center phone number"
        }
      }
    },
    "uniqueSections": {
      "type": "array",
      "description": "Park-specific deep-dive sections (2-3 per park)",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {
            "type": "string",
            "description": "HTML section ID (e.g., 'narrows', 'rim-to-rim')"
          },
          "title": {
            "type": "string",
            "description": "Section display title"
          },
          "icon": {
            "type": "string",
            "description": "Emoji icon for the section header"
          },
          "navLabel": {
            "type": "string",
            "description": "Short label for the nav bar"
          },
          "content": {
            "type": "string",
            "description": "HTML content for the section body"
          }
        }
      }
    },
    "alerts": {
      "type": "array",
      "description": "Current park alerts (danger, warning, info)",
      "items": {
        "type": "object",
        "properties": {
          "level": {
            "type": "string",
            "enum": ["danger", "warn", "info"]
          },
          "title": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "mapPOIs": {
      "type": "array",
      "description": "Points of interest for the interactive Leaflet map",
      "items": {
        "type": "object",
        "properties": {
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "label": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
